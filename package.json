{
  "name": "idc-device-management",
  "version": "2.3.2",
  "description": "IDC设备管理系统",
  "author": "gituib",
  "license": "MIT",
  "homepage": "https://github.com/gituib/idc_assest#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gituib/idc_assest.git"
  },
  "bugs": {
    "url": "https://github.com/gituib/idc_assest/issues"
  },
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm run dev",
    "start:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "deploy": "node install.js",
    "update": "node update.js",
    "uninstall": "node uninstall.js"
  },
  "keywords": [
    "idc",
    "device",
    "management"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "all": "^0.0.0",
    "papaparse": "^5.5.3"
  }
}
